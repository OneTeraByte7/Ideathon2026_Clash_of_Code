# ─────────────────────────────────────────────
#  Asclepius AI — Production Environment Template
# ─────────────────────────────────────────────
# Copy this file to backend/.env and fill in your values

# ── App Configuration ─────────────────────────
APP_NAME=Asclepius AI
DEBUG=false

# ── Database Configuration ────────────────────
# Get from MongoDB Atlas: https://cloud.mongodb.com
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/Asclepius?retryWrites=true&w=majority
DATABASE_NAME=Asclepius

# ── AI Configuration ──────────────────────────
# Get from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram Bot Configuration ────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Get chat IDs using @userinfobot or the test script
TELEGRAM_NURSE_CHAT_ID=your_nurse_chat_id
TELEGRAM_DOCTOR_CHAT_ID=your_doctor_chat_id

# ── Risk Thresholds ───────────────────────────
RISK_WARNING_THRESHOLD=40
RISK_CRITICAL_THRESHOLD=70

# ── System Configuration ──────────────────────
SLIDING_WINDOW_MINUTES=240

# ── Webhook URLs (Optional) ───────────────────
# For Slack/Teams notifications
NURSE_WEBHOOK_URL=
DOCTOR_WEBHOOK_URL=